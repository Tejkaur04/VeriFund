			"methods": {
				"addMilestone(uint256,string,uint256)": {
					"params": {
						"_amountInEther": "How much ETH you are requesting to release",
						"_campaignId": "Which campaign this belongs to",
						"_description": "What you did / what the money is for"
					}
				},
				"claimRefund(uint256)": {
					"params": {
						"_campaignId": "Which campaign to refund from"
					}
				},
				"createCampaign(string,string,uint256,uint256)": {
					"params": {
						"_daysToRaise": "How many days donors have to contribute (1–90)",
						"_description": "Full story of the campaign",
						"_goalInEther": "How much ETH to raise e.g. 1 = 1 ETH",
						"_title": "Short name e.g. \"Medical bills for Raju\""
					}
				},
				"donate(uint256)": {
					"params": {
						"_campaignId": "The ID of the campaign to donate to"
					}
				},
				"vote(uint256,uint256,bool)": {
					"params": {
						"_approve": "true = approve release, false = reject",
						"_campaignId": "Which campaign",
						"_milestoneId": "Which milestone to vote on"
					}
				}
			},
			"title": "CrowdFund — Transparent Blockchain Crowdfunding",
			"version": 1
		},
		"userdoc": {
			"kind": "user",
			"methods": {
				"addMilestone(uint256,string,uint256)": {
					"notice": "Creator submits a milestone to request fund release"
				},
				"claimRefund(uint256)": {
					"notice": "If the goal wasn't met by deadline, donors can get their money back"
				},
				"createCampaign(string,string,uint256,uint256)": {
					"notice": "Start a new fundraising campaign"
				},
				"donate(uint256)": {
					"notice": "Send ETH to support a campaign"
				},
				"getCampaign(uint256)": {
					"notice": "Get all details of a campaign"
				},
				"getDonorCount(uint256)": {
					"notice": "Get total number of donors for a campaign"
				},
				"getMilestone(uint256,uint256)": {
					"notice": "Get all details of a milestone"
				},
				"getMyDonation(uint256)": {
					"notice": "How much has a specific donor contributed to a campaign"
				},
				"getTimeRemaining(uint256)": {
					"notice": "Get time remaining for a campaign in seconds (0 if ended)"
				},
				"vote(uint256,uint256,bool)": {
					"notice": "Donors vote to approve or reject a fund release request"
				}
			},
			"notice": "People donate to campaigns. Funds only release when donors approve milestones.         If the goal isn't met by deadline, everyone gets a full refund automatically.",
